# --- Default behavior ---
* text=auto

# --- Force LF for code (important for Docker/Linux) ---
*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
Dockerfile text eol=lf

# --- Windows-specific files (keep CRLF if you ever add them) ---
*.bat text eol=crlf
*.cmd text eol=crlf

# --- Binary files (do not modify line endings) ---
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.mp4 binary
*.mov binary
*.zip binary

# --- Prevent diff noise for lock files ---
package-lock.json -diff
yarn.lock -diff
pnpm-lock.yaml -diff
